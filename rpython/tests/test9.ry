def heavy(n: int) -> int {
    i: int = 0;
    res: int = 0;
    while i < n {
        res = res + i;
        i = i + 1;
    };
    return res;
};

def main() -> int {
    i: int = 0;
    res: int = 0;
    while i < 20000 {
        res = heavy(5000);
        i = i + 1;
    };
    return res;
};

return main();