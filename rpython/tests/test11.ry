import torch

a: int = torch.tensor(3)
b: int = torch.tensor(4)
c: int = a.add(b)
print(c)                    // tensor(7)

d: int = a.mul(b)
print(d)                    // tensor(12)

e: int = d.sub(c)
print(e)                    // tensor(5)


z: int = torch.zeros(5)
print(z)                    // tensor([0., 0., 0., 0., 0.])

o: int = torch.ones(5)
print(o)                    // tensor([1., 1., 1., 1., 1.])

r: int = torch.arange(6)
print(r)                    // tensor([0, 1, 2, 3, 4, 5])


s: int = torch.ones(10).sum()
print(s)                    // tensor(10.)

m: int = torch.arange(4).float().mean()
print(m)                    // tensor(1.5000)


p: int = torch.tensor(2).pow(10)
print(p)                    // tensor(1024)

chain: int = torch.ones(4).mul(torch.ones(4)).sum()
print(chain)                // tensor(4.)

mat: int = torch.arange(6).float().reshape(2, 3)
print(mat)
// tensor([[0., 1., 2.],
//         [3., 4., 5.]])

m1: int = torch.ones(2, 2)
m2: int = torch.ones(2, 2).mul(2)
mm: int = torch.matmul(m1, m2)
print(mm)
// tensor([[4., 4.],
//         [4., 4.]])


rng: int = torch.arange(1, 6)
print(rng.max())            // tensor(5)
print(rng.min())            // tensor(1)


w: int = torch.tensor(3).float().requires_grad_(true)
loss: int = w.mul(w)
loss.backward()
grad: int = w.grad
print(grad)                 // tensor(6.)

detached: int = loss.detach().item()
print(detached)             // 9.0


acc: int = torch.tensor(0)
i: int = 0
while i < 5 {
    acc = acc.add(torch.tensor(i))
    i = i + 1
}
print(acc)                  // tensor(10)
print(acc.item())           // 10


big: int = torch.zeros(3, 4, 5)
print(big.numel())          // 60
print(big.size())           // torch.Size([3, 4, 5])

linear: int = torch.nn.Linear(4, 2)
inp: int = torch.ones(1, 4)
out: int = linear.forward(inp)
print(out.shape)            // torch.Size([1, 2])


fn: int = torch.nn.functional
neg: int = torch.tensor(0 - 5).float()
print(fn.relu(neg))         // tensor(0.)

pos: int = torch.tensor(3).float()
print(fn.relu(pos))         // tensor(3.)

// pred = w*x, target = 2*x, loss = (pred - target)^2 at x=1, w=1
// d_loss/d_w = 2*(pred-target)*x = 2*(1-2)*1 = -2

wx: int = torch.tensor(1).float().requires_grad_(true)
target: int = torch.tensor(2).float()
pred: int = wx.mul(torch.tensor(1).float())
diff: int = pred.sub(target)
mse: int = diff.mul(diff)
mse.backward()
print(wx.grad)              // tensor(-2.)